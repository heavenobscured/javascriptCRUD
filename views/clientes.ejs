<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.4.1/dist/css/bootstrap.min.css" integrity="sha384-Vkoo8x4CGsO3+Hhxv8T/Q5PaXtkKtu6ug5TOeNV6gBiFeWPGFN9MuhOf23Q9Ifjh" crossorigin="anonymous">
    <style>
        body {
            background: linear-gradient(rgba(3, 7, 18, 0.82), rgba(3, 7, 18, 0.82)),
                        url('https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=1600&q=80') center/cover no-repeat;
            min-height: 100vh;
            color: #f8f9fa;
        }

        .card-dark {
            background: rgba(10, 20, 35, 0.9);
            border: 1px solid rgba(255, 255, 255, 0.12);
        }

        .form-control {
            color: #1a1a1a !important;
        }

        .form-control::placeholder {
            color: #666 !important;
        }

        .list-group-item {
            color: #000 !important;
        }
    </style>
    <title>Gestión de clientes</title>
</head>
<body>
    <div class="container py-5">
        <div class="card card-dark shadow-lg rounded p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="display-4 font-weight-bold text-primary">Gestión de clientes</h1>
                    <p class="lead text-light">Administra los clientes del sistema de forma sencilla y ordenada.</p>
                </div>
                <a href="/" class="btn btn-outline-light">Volver al inicio</a>
            </div>

            <div class="row">
                <div class="col-lg-5 mb-4">
                    <h3 class="text-light mb-3">Agregar cliente</h3>
                    <form action="/clientes" method="POST">
                        <div class="form-group">
                            <label for="nombre">Nombre completo</label>
                            <input type="text" class="form-control" id="nombre" name="nombre" placeholder="Nombre completo" required>
                        </div>
                        <div class="form-group">
                            <label for="email">Correo</label>
                            <input type="email" class="form-control" id="email" name="email" placeholder="Correo" required>
                        </div>
                        <div class="form-group">
                            <label for="calle">Calle</label>
                            <input type="text" class="form-control" id="calle" name="calle" placeholder="Calle" required>
                        </div>
                        <div class="form-group">
                            <label for="telefono">Número</label>
                            <input type="number" class="form-control" id="telefono" name="telefono" placeholder="Número" required>
                        </div>
                        <div class="form-group">
                            <label for="comuna">Comuna</label>
                            <input type="text" class="form-control" id="comuna" name="comuna" placeholder="Comuna" required>
                        </div>
                        <div class="form-group">
                            <label for="ciudad">Ciudad</label>
                            <input type="text" class="form-control" id="ciudad" name="ciudad" placeholder="Ciudad" required>
                        </div>
                        <button type="submit" class="btn btn-primary btn-block">Enviar</button>
                    </form>
                </div>

                <div class="col-lg-7">
                    <h3 class="text-light mb-3">Lista de clientes</h3>
                    <ul class="list-group">
                        <% clientes.forEach(c => { %>
                            <li class="list-group-item" id="fila-<%= c._id %>">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <strong><%= c.nombre %></strong> - <%= c.email %>
                                        <br>
                                        <small class="text-muted">Dirección: <%= c.direccion.calle %> <%= c.direccion.numero %>, <%= c.direccion.comuna %>, <%= c.direccion.ciudad %></small>
                                    </div>
                                    <div>
                                        <button class="btn btn-sm btn-outline-primary" onclick="toggleEditar('<%= c._id %>')">Editar</button>
                                        <button class="btn btn-sm btn-outline-danger" onclick="eliminar('<%= c._id %>')">Eliminar</button>
                                    </div>
                                </div>

                                <form class="mt-3 d-none" id="form-editar-<%= c._id %>" onsubmit="guardarEdicion(event, '<%= c._id %>')">
                                    <div class="form-group">
                                        <input type="text" class="form-control" name="nombre" value="<%= c.nombre %>" required>
                                    </div>
                                    <div class="form-group">
                                        <input type="email" class="form-control" name="email" value="<%= c.email %>" required>
                                    </div>
                                    <div class="form-group">
                                        <input type="text" class="form-control" name="telefono" value="<%= c.telefono %>" placeholder="Teléfono">
                                    </div>
                                    <div class="form-group">
                                        <input type="text" class="form-control" name="calle" value="<%= c.direccion.calle %>" placeholder="Calle" required>
                                    </div>
                                    <div class="form-group">
                                        <input type="number" class="form-control" name="numero" value="<%= c.direccion.numero %>" placeholder="Número">
                                    </div>
                                    <div class="form-group">
                                        <input type="text" class="form-control" name="comuna" value="<%= c.direccion.comuna %>" placeholder="Comuna" required>
                                    </div>
                                    <div class="form-group">
                                        <input type="text" class="form-control" name="ciudad" value="<%= c.direccion.ciudad %>" placeholder="Ciudad" required>
                                    </div>
                                    <div class="form-group">
                                        <input type="text" class="form-control" name="codigoPostal" value="<%= c.direccion.codigoPostal %>" placeholder="Código postal">
                                    </div>
                                    <button type="submit" class="btn btn-sm btn-primary">Guardar cambios</button>
                                    <button type="button" class="btn btn-sm btn-secondary" onclick="toggleEditar('<%= c._id %>')">Cancelar</button>
                                </form>
                            </li>
                        <% }) %>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <script>
        async function eliminar(id) {
            if (confirm('¿Eliminar este cliente?')) {
                await fetch(`/clientes/${id}`, { method: 'DELETE' });
                location.reload();
            }
        }

        function toggleEditar(id) {
            document.getElementById(`form-editar-${id}`).classList.toggle('d-none');
        }

        async function guardarEdicion(event, id) {
            event.preventDefault();
            const form = event.target;
            const datos = {
                nombre: form.nombre.value,
                email: form.email.value,
                telefono: form.telefono.value,
                calle: form.calle.value,
                numero: form.numero.value,
                comuna: form.comuna.value,
                ciudad: form.ciudad.value,
                codigoPostal: form.codigoPostal.value
            };

            const respuesta = await fetch(`/clientes/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(datos)
            });

            if (!respuesta.ok) {
                alert('No se pudo actualizar el cliente');
                return;
            }
            location.reload();
        }
    </script>
</body>
</html>