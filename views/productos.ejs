<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.4.1/dist/css/bootstrap.min.css" integrity="sha384-Vkoo8x4CGsO3+Hhxv8T/Q5PaXtkKtu6ug5TOeNV6gBiFeWPGFN9MuhOf23Q9Ifjh" crossorigin="anonymous">
    <style>
        body {
            background: linear-gradient(rgba(3, 7, 18, 0.82), rgba(3, 7, 18, 0.82)),
                        url('https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=1600&q=80') center/cover no-repeat;
            min-height: 100vh;
            color: #f8f9fa;
        }

        .card-dark {
            background: rgba(10, 20, 35, 0.9);
            border: 1px solid rgba(255, 255, 255, 0.12);
        }

        .form-control {
            color: #1a1a1a !important;
        }

        .form-control::placeholder {
            color: #666 !important;
        }

        .list-group-item {
            color: #000 !important;
        }
    </style>
    <title>Gestión de productos</title>
</head>
<body>
    <div class="container py-5">
        <div class="card card-dark shadow-lg rounded p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="display-4 font-weight-bold text-warning">Gestión de productos</h1>
                    <p class="lead text-light">Administra el catálogo de productos del sistema.</p>
                </div>
                <a href="/" class="btn btn-outline-light">Volver al inicio</a>
            </div>

            <div class="row">
                <div class="col-lg-5 mb-4">
                    <h3 class="text-light mb-3">Agregar producto</h3>
                    <form action="/productos" method="POST">
                        <div class="form-group">
                            <label for="nombre">Nombre</label>
                            <input type="text" class="form-control" id="nombre" name="nombre" placeholder="Nombre" required>
                        </div>
                        <div class="form-group">
                            <label for="precio">Precio</label>
                            <input type="number" class="form-control" id="precio" name="precio" placeholder="Precio" step="0.01" required>
                        </div>
                        <div class="form-group">
                            <label for="stock">Stock</label>
                            <input type="number" class="form-control" id="stock" name="stock" placeholder="Stock" required>
                        </div>
                        <button type="submit" class="btn btn-warning btn-block">Guardar</button>
                    </form>
                </div>

                <div class="col-lg-7">
                    <h3 class="text-light mb-3">Lista de productos</h3>
                    <ul class="list-group">
                        <% productos.forEach(p => { %>
                            <li class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong><%= p.nombre %></strong> - $<%= p.precio %> - Stock: <%= p.stock %>
                                    </div>
                                    <div>
                                        <button class="btn btn-sm btn-outline-primary" onclick="toggleEditar('<%= p._id %>')">Editar</button>
                                        <button class="btn btn-sm btn-outline-danger" onclick="eliminar('<%= p._id %>')">Eliminar</button>
                                    </div>
                                </div>

                                <form class="mt-3 d-none" id="form-editar-<%= p._id %>" onsubmit="guardarEdicion(event, '<%= p._id %>')">
                                    <div class="form-group">
                                        <input type="text" class="form-control" name="nombre" value="<%= p.nombre %>" required>
                                    </div>
                                    <div class="form-group">
                                        <textarea class="form-control" name="descripcion" placeholder="Descripción"><%= p.descripcion %></textarea>
                                    </div>
                                    <div class="form-group">
                                        <input type="number" class="form-control" name="precio" value="<%= p.precio %>" step="0.01" required>
                                    </div>
                                    <div class="form-group">
                                        <input type="number" class="form-control" name="stock" value="<%= p.stock %>" required>
                                    </div>
                                    <div class="form-group">
                                        <input type="text" class="form-control" name="categoria" value="<%= p.categoria %>" placeholder="Categoría">
                                    </div>
                                    <button type="submit" class="btn btn-sm btn-warning">Guardar cambios</button>
                                    <button type="button" class="btn btn-sm btn-secondary" onclick="toggleEditar('<%= p._id %>')">Cancelar</button>
                                </form>
                            </li>
                        <% }) %>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <script>
        async function eliminar(id) {
            if (confirm('¿Eliminar este producto?')) {
                await fetch(`/productos/${id}`, { method: 'DELETE' });
                location.reload();
            }
        }

        function toggleEditar(id) {
            document.getElementById(`form-editar-${id}`).classList.toggle('d-none');
        }

        async function guardarEdicion(event, id) {
            event.preventDefault();
            const form = event.target;
            const datos = {
                nombre: form.nombre.value,
                descripcion: form.descripcion.value,
                precio: form.precio.value,
                stock: form.stock.value,
                categoria: form.categoria.value
            };

            const respuesta = await fetch(`/productos/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(datos)
            });

            if (!respuesta.ok) {
                alert('No se pudo actualizar el producto');
                return;
            }
            location.reload();
        }
    </script>
</body>
</html>